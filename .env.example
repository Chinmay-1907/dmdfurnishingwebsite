# EmailJS configuration (copy to .env or .env.local)
# Replace placeholders with values from your EmailJS account

REACT_APP_EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY
REACT_APP_EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
REACT_APP_EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID

# After setting these, stop and restart `npm start`.

# Backend API base (dev server)
REACT_APP_API_BASE=http://localhost:3002

# SMTP configuration for Nodemailer backend
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
MAIL_FROM="DMD Furnishing Website" <no-reply@yourdomain.com>
MAIL_TO=sales@dmdfurnishing.com